# Application environment
MEDNOVA_ENV=development
FLASK_ENV=development
FLASK_SECRET_KEY=your-secret-key

# Database
MEDNOVA_DB_PATH=database/nafdac_intelligence.db
DATABASE_PATH=database/nafdac_intelligence.db

# Cron and scheduler
SYNC_CRON_SECRET=your-cron-secret
SYNC_SCHEDULER_ENABLED=false

# Tavily
TAVILY_API_KEY=your-tavily-api-key

# Resend email
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=info@mednovalife.com
FROM_EMAIL=info@mednovalife.com
SENDER_NAME=MedNova Lifesciences
SENDER_DOMAIN=mednovalife.com

# Frontend / backend URLs
VITE_API_BASE_URL=http://localhost:5000
BACKEND_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000
MEDNOVA_CRM_FRONTEND_URL=http://localhost:5173

# Optional Supabase sync (only if using cloud sync)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
